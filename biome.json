{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"indentWidth": 4
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"formatWithErrors": true,
		"bracketSpacing": true,
		"bracketSameLine": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noUnknownAtRules": "off",
				"noConsole": "off",
				"useIterableCallbackReturn": "off"
			},
			"style": {
				"noMagicNumbers": "off",
				"useBlockStatements": "off"
			},
			"complexity": {
				"noForEach": "off"
			},
			"performance": {
				"noBarrelFile": "off"
			}
		},
		"domains": {
			"next": "recommended",
			"react": "recommended"
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"extends": ["ultracite/core", "ultracite/react"]
}
