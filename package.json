{
	"name": "gliff",
	"version": "0.0.9",
	"description": "React components for Gliff, including Icons and Lottie animations.",
	"author": {
		"name": "Ritik Srivastava"
	},
	"license": "ISC",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome check",
		"format": "biome format --write",
		"clean": "rm -rf node_modules pnpm-lock.yaml && pnpm install"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"dependencies": {
		"@lottiefiles/dotlottie-react": "^0.17.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.12",
		"@types/node": "^25.0.10",
		"@types/react": "^19.2.9",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"terser": "^5.46.0",
		"typescript": "~5.8.2",
		"ultracite": "^7.0.12",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vite-plugin-lib-inject-css": "^2.2.2"
	},
	"homepage": "https://github.com/itzzritik/Gliff#readme",
	"bugs": {
		"url": "https://github.com/itzzritik/Gliff/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/itzzritik/Gliff"
	},
	"keywords": [
		"gliff",
		"react",
		"icon",
		"lottie",
		"components",
		"ui",
		"animations"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"main": "dist/gliff.js",
	"module": "dist/gliff.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/gliff.js",
			"default": "./dist/gliff.js"
		},
		"./styles": "./dist/index.css"
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
