{
	"name": "gliff",
	"version": "0.0.1",
	"description": "React components for Gliff, including Icons and Lottie animations.",
	"author": {
		"name": "Ritik Srivastava"
	},
	"license": "ISC",
	"homepage": "https://github.com/itzzritik/Gliff#readme",
	"bugs": {
		"url": "https://github.com/itzzritik/Gliff/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/itzzritik/Gliff"
	},
	"keywords": [
		"gliff",
		"react",
		"icon",
		"lottie",
		"components",
		"ui",
		"animations"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"main": "dist/gliff.umd.cjs",
	"module": "dist/gliff.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/gliff.js",
			"require": "./dist/gliff.umd.cjs"
		},
		"./styles.css": "./dist/style.css"
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check",
		"format": "biome format --write"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"dependencies": {
		"@lottiefiles/dotlottie-react": "^0.17.13",
		"clsx": "^2.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^24.10.9",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/browser-playwright": "^4.0.17",
		"@vitest/coverage-v8": "^4.0.17",
		"playwright": "^1.57.0",
		"typescript": "~5.9.3",
		"ultracite": "^7.0.11",
		"vite": "^7.2.4",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.17"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
